{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": ".",

    "lib": ["ES2022"],

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,
    "strict": false,

    "types": ["node"]
  },

  "include": [
    "server.ts",
    "db.ts",
    "routes/**/*.ts",
    "controllers/**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "data/seed.ts"
  ]
}